# ============================================================
#  IEEE Rama Estudiantil UNMSM — Variables de Entorno
#  Copiar este archivo como .env y rellenar los valores reales
# ============================================================

# ── Seguridad ──────────────────────────────────────────────
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres aleatorios)
JWT_SECRET=cambia_esto_por_una_clave_muy_segura_de_al_menos_32_chars

# ── Base de Datos ──────────────────────────────────────────
# Ruta al archivo SQLite (en Docker usa /data/database.sqlite)
DB_PATH=./backend/database.sqlite

# ── Servidor ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# URL pública del sitio (para RSS, Open Graph y correos)
SITE_URL=https://ieee-unmsm.org

# Orígenes CORS permitidos (separados por coma)
CORS_ORIGIN=https://ieee-unmsm.org

# ── Correo Electrónico (SMTP Gmail o SMTP propio) ──────────
# Si se deja vacío, el formulario de contacto opera en modo simulación
EMAIL_USER=ieee@unmsm.edu.pe
EMAIL_PASS=tu_contrasena_de_aplicacion_gmail

# Correo del director de rama que recibe notificaciones y mensajes de contacto
EMAIL_DIRECTOR=director@unmsm.edu.pe
